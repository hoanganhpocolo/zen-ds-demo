{
  "name": "@zen/icons",
  "version": "0.1.0",
  "description": "Zen Design System — Icon library (line, solid, social)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./line": {
      "import": "./dist/line/index.js",
      "require": "./dist/line/index.cjs",
      "types": "./dist/line/index.d.ts"
    },
    "./solid": {
      "import": "./dist/solid/index.js",
      "require": "./dist/solid/index.cjs",
      "types": "./dist/solid/index.d.ts"
    },
    "./social": {
      "import": "./dist/social/index.js",
      "require": "./dist/social/index.cjs",
      "types": "./dist/social/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "node scripts/generate.js",
    "build": "npm run generate && tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "@types/react": "^19.1.6",
    "typescript": "^5.8.3",
    "tsup": "^8.5.0",
    "svgo": "^3.3.2"
  },
  "keywords": ["icons", "react", "svg", "design-system", "zen"],
  "license": "MIT"
}
